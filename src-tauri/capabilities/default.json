{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-copy-file",
    "fs:allow-app-write",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read",
    "fs:allow-app-read-recursive",
    "fs:allow-app-meta",
    "fs:allow-app-meta-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$PICTURE/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DOCUMENT/**"
        }
      ]
    },
    "shell:default",
    "shell:allow-open",
    "updater:default",
    "process:allow-restart"
  ]
}
